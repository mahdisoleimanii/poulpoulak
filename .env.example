# Copy to `.env` and fill in your real values.

# Get a token from @BotFather on Telegram.
BOT_TOKEN=123456789:replace-me-with-real-token

# Comma- or whitespace-separated list of Telegram user IDs that count as
# super-admins. Super-admins are the only people who can add the bot to a
# group (req 5). Find your user id with @userinfobot.
SUPER_ADMINS=111111111,222222222

# Public repo URL shown to non-admins in /start.
REPO_URL=https://github.com/your-username/dong-bot

# Where per-group roster/authorized-chat data is kept. Default: ./data
DATA_DIR=data

# Inactivity timeout for the wizard, in seconds (req 17). Default: 300
SESSION_TIMEOUT_SECONDS=300

# Cap on member buttons shown (req 0.5 answer: keep groups < 20 members).
MAX_MEMBER_BUTTONS=20